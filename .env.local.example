# Turso (libSQL). For local dev use a file DB:
#   TURSO_DATABASE_URL=file:local.db
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Optional — enables the AI story coach + question matcher
ANTHROPIC_API_KEY=
